VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Backend-only Supabase service role key for scheduler/email workers
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App origin used to build OAuth redirect URLs when META_REDIRECT_URI is not set
APP_URL=http://localhost:5173

# Meta / Instagram OAuth (server-only — never prefix with VITE_)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=http://localhost:5173/auth/instagram/callback
META_GRAPH_VERSION=v21.0
OAUTH_STATE_SECRET=your-random-oauth-state-secret

# Email worker configuration
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-smtp-user
EMAIL_SMTP_PASS=your-smtp-password
EMAIL_FROM="Creatory AI <no-reply@example.com>"
