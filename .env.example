# Application
APP_URL=https://your-app.example.com

# External APIs
API_BASE_URL=https://graph.facebook.com
META_OAUTH_BASE_URL=https://www.facebook.com
META_GRAPH_VERSION=v21.0

# Meta / Instagram OAuth (server-only)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
META_REDIRECT_URI=https://your-app.example.com/auth/instagram/callback
OAUTH_STATE_SECRET=your-random-oauth-state-secret

# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email worker configuration
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=your-smtp-user
EMAIL_SMTP_PASS=your-smtp-password
EMAIL_FROM="Creatory AI <no-reply@example.com>"
